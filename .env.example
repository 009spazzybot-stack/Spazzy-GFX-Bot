# Get your Discord bot token from: https://discord.com/developers/applications
TOKEN=your_discord_bot_token_here

# Optional Google Custom Search API credentials for Fortnite skin lookup
# Get a key from https://console.developers.google.com and create a Custom Search Engine
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_CSE_ID=your_google_custom_search_engine_id_here
